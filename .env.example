# Copy these values into Synology Container Manager or the service environment.
# Never commit the real .env file.
SPRING_PROFILES_ACTIVE=mariadb
BROCA_DB_URL=jdbc:mariadb://localhost:3306/broca_website?useUnicode=true&characterEncoding=utf8
BROCA_DB_USERNAME=broca_app
BROCA_DB_PASSWORD=replace-with-a-long-random-password

BROCA_BOOTSTRAP_ADMIN_USERNAME=director
BROCA_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-long-unique-password
BROCA_BOOTSTRAP_TEACHER_USERNAME=teacher
BROCA_BOOTSTRAP_TEACHER_PASSWORD=replace-with-a-different-long-password

BROCA_SERVER_PORT=8080
BROCA_SECURE_COOKIES=true

LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_SENDING_ENABLED=false
LINE_LIFF_ROLLCALL_ID=
